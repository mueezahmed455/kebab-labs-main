# Supabase (Optional — for order persistence)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Square Payments (Required for Apple Pay / Card Payments)
# 1. Create a free Square account at https://squareup.com
# 2. Link your UK bank account in the Square Dashboard
# 3. Go to Developer Dashboard > Create Application
# 4. Copy your credentials below
# 5. Deposits go directly to your linked bank account (1-2 business days)
SQUARE_ACCESS_TOKEN="your-square-access-token"
SQUARE_LOCATION_ID="your-square-location-id"
VITE_SQUARE_APP_ID="your-square-application-id"

# Apple Pay
VITE_APPLE_PAY_MERCHANT_ID=merchant.com.kebablab
